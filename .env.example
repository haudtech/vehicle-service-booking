# Vehicle Service Booking API - Environment Configuration (.env.example)
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Customize the values for your local environment
# 3. .env is automatically loaded when running the application
# 4. This file (.env.example) is committed to Git, .env is not
#
# IMPORTANT: Never commit .env with sensitive data (passwords, API keys, etc.)

# ===================================================================
# ASP.NET Core Environment
# ===================================================================
# Options: Development, Staging, Production
# Default: Development
ASPNETCORE_ENVIRONMENT=Development

# ===================================================================
# API Server Configuration
# ===================================================================
# Uncomment and customize if needed
# ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001

# ===================================================================
# Logging Configuration
# ===================================================================
# LogLevel options: Debug, Information, Warning, Error, Critical
# 
# Development: Debug level for all components
# Staging: Debug for app, Info for frameworks
# Production: Information for app, Warning for frameworks
#
LOGGING__LOGLEVEL__DEFAULT=Debug
LOGGING__LOGLEVEL__MICROSOFT=Debug
LOGGING__LOGLEVEL__MICROSOFT_ASPNETCORE=Debug
LOGGING__LOGLEVEL__MICROSOFT_ENTITYFRAMEWORKCORE=Debug

# ===================================================================
# Database Configuration
# ===================================================================
# Currently using in-memory database for development
# 
# For SQL Server (future):
# Server=localhost;Database=VehicleServiceBooking;Trusted_Connection=true;TrustServerCertificate=true;
#
# For PostgreSQL (future):
# Host=localhost;Database=vehicle_service_booking;Username=dev;Password=devpass
#
# DATABASE_URL=

# ===================================================================
# Scheduling Configuration
# ===================================================================
# Slot duration in minutes (typical: 15, 30, 60)
SCHEDULING__SLOTLENGTHMINUTES=30

# Note: Working hours are managed at the Dealership entity level
# via the BusinessHours collection, not as global configuration.
# Each dealership can have different operating hours.

# ===================================================================
# Feature Flags (Future Use)
# ===================================================================
# Enable/disable features for testing
# FEATURE__ENABLESWAGGER=true
# FEATURE__ENABLECACHING=false
# FEATURE__ENABLELOGGING=true

# ===================================================================
# Integration Settings (Future Use)
# ===================================================================
# API keys and endpoints for external services
# EXTERNAL_API_KEY=your-key-here
# EXTERNAL_API_ENDPOINT=https://api.example.com

# ===================================================================
# Notes
# ===================================================================
# - Variable naming convention: Use __ for nested JSON properties
#   Example: LOGGING__LOGLEVEL__DEFAULT = Logging:LogLevel:Default
#
# - This file is loaded by Program.cs using DotNetEnv
#   Location: src/VehicleServiceBooking.Api/Program.cs
#
# - If .env file doesn't exist, appsettings.json is used
#
# - Environment variables in .env override appsettings.{Environment}.json
#   Precedence: .env > command-line vars > appsettings.{Env}.json > appsettings.json
#
# - For sensitive data (in real projects), use:
#   - Azure Key Vault (Production)
#   - AWS Secrets Manager (Production)
#   - Docker secrets (Container environments)
#   - User Secrets (Development only: dotnet user-secrets set ...)

