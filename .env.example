# Vehicle Service Booking API - Environment Configuration (.env.example)
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Customize the values for your local environment
# 3. This file (.env.example) is committed to Git, .env is not

# ===================================================================
# Environment
# ===================================================================
ASPNETCORE_ENVIRONMENT=Development

# ===================================================================
# Logging
# ===================================================================
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__MICROSOFT=Warning

# ===================================================================
# CORS Configuration
# ===================================================================
# Allowed origins for development frontend
CORS__ALLOWEDORIGINS__0=http://localhost:3000
CORS__ALLOWEDORIGINS__1=http://localhost:5173

# Allowed HTTP methods
CORS__ALLOWEDMETHODS__0=GET
CORS__ALLOWEDMETHODS__1=POST
CORS__ALLOWEDMETHODS__2=PUT
CORS__ALLOWEDMETHODS__3=DELETE
CORS__ALLOWEDMETHODS__4=PATCH
CORS__ALLOWEDMETHODS__5=OPTIONS

# Allowed headers
CORS__ALLOWEDHEADERS__0=*

# Preflight cache duration (seconds)
CORS__MAXAGE=300

# Allow credentials
CORS__ALLOWCREDENTIALS=true

# Policy name
CORS__POLICYNAME=DevelopmentCorsPolicy

# ===================================================================
# Scheduling
# ===================================================================
SCHEDULING__SLOTLENGTHMINUTES=30

# ===================================================================
# Notes
# ===================================================================
# - Variable naming: Use __ for nested JSON properties
#   Example: CORS__ALLOWEDORIGINS__0 = Cors:AllowedOrigins[0]
#
# - This file is loaded by Program.cs using DotNetEnv
#
# - Environment variables in .env override appsettings files
#   Precedence: .env > appsettings.{Env}.json > appsettings.json


