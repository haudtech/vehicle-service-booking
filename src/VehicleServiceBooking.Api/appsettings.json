{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "Observability": {
    "Serilog": {
      "MinimumLevel": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning"
      },
      "EnableConsole": true,
      "EnableFile": true,
      "FilePath": "logs/app-.txt",
      "RollingInterval": "Day"
    },
    "OpenTelemetry": {
      "Tracing": {
        "UseAspNetCoreInstrumentation": true,
        "UseEntityFrameworkCoreInstrumentation": true,
        "Exporter": "Console"
      }
    }
  },

  "Scheduling": {
    "SlotLengthMinutes": 30
  }
}