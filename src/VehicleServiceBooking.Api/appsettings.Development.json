{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Observability": {
    "Serilog": {
      "MinimumLevel": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning"
      },
      "EnableConsole": true,
      "EnableFile": true,
      "FilePath": "logs/app-.txt",
      "RollingInterval": "Day"
    },
    "OpenTelemetry": {
      "Tracing": {
        "UseAspNetCoreInstrumentation": true,
        "UseEntityFrameworkCoreInstrumentation": true,
        "Exporter": "Console"
      }
    }
  },
  "Scheduling": {
    "SlotLengthMinutes": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:5173"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "*"
    ],
    "ExposedHeaders": [],
    "MaxAge": 300,
    "AllowCredentials": true,
    "PolicyName": "DevelopmentCorsPolicy"
  },
  "StaticDataCache": {
    "Enabled": true,
    "CacheTimeSlots": true,
    "CacheAppointmentStatuses": true,
    "CacheServiceStatuses": true,
    "TimeSlotsTtlMinutes": 30,
    "AppointmentStatusesTtlMinutes": 30,
    "ServiceStatusesTtlMinutes": 30
  },
  "Idempotency": {
    "Enabled": true,
    "RequireHeader": false,
    "KeyMaxLength": 100,
    "EntryTtlHours": 24
  }
}
