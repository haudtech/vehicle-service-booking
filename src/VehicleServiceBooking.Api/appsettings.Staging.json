{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Debug"
    }
  },
  "Observability": {
    "Serilog": {
      "MinimumLevel": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning"
      },
      "EnableConsole": true,
      "EnableFile": false,
      "RollingInterval": "Day"
    },
    "OpenTelemetry": {
      "Tracing": {
        "UseAspNetCoreInstrumentation": true,
        "UseEntityFrameworkCoreInstrumentation": true,
        "Exporter": "Console"
      }
    }
  },
  "Scheduling": {
    "SlotLengthMinutes": 30,
    "WorkingHoursStart": "08:00:00",
    "WorkingHoursEnd": "18:00:00"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://staging.example.com",
      "https://staging-admin.example.com"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "Authorization",
      "Accept",
      "Accept-Language"
    ],
    "ExposedHeaders": [
      "X-Total-Count",
      "X-Page-Number",
      "X-Page-Size"
    ],
    "MaxAge": 1800,
    "AllowCredentials": true,
    "PolicyName": "StagingCorsPolicy"
  },
  "StaticDataCache": {
    "Enabled": true,
    "CacheTimeSlots": true,
    "CacheAppointmentStatuses": true,
    "CacheServiceStatuses": true,
    "TimeSlotsTtlMinutes": 1440,
    "AppointmentStatusesTtlMinutes": 1440,
    "ServiceStatusesTtlMinutes": 1440
  },
  "AllowedHosts": "*"
}
